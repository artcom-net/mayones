{
  "version": 6,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "installDir": "${sourceDir}/out/install/${presetName}",
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_RUNTIME_OUTPUT_DIRECTORY": "${sourceDir}/out/build/${presetName}/bin",
        "CMAKE_ARCHIVE_OUTPUT_DIRECTORY": "${sourceDir}/out/build/${presetName}/lib",
        "CMAKE_LIBRARY_OUTPUT_DIRECTORY": "${sourceDir}/out/build/${presetName}/lib",
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
      }
    },
    {
      "name": "windows-base",
      "hidden": true,
      "inherits": ["base"],
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "debug-base",
      "hidden": true,
      "cacheVariables": {
        "ENABLE_LTO": "OFF",
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release-base",
      "hidden": true,
      "cacheVariables": {
        "ENABLE_LTO": "ON",
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "msvc-base",
      "hidden": true,
      "inherits": ["windows-base"],
      "cacheVariables": {
        "CMAKE_C_COMPILER": "cl.exe",
        "CMAKE_CXX_COMPILER": "cl.exe",
        "VCPKG_TARGET_TRIPLET": "x64-windows-static-md"
      }
    },
    {
      "name": "msvc-debug",
      "inherits": ["msvc-base", "debug-base"]
    },
    {
      "name": "msvc-release",
      "inherits": ["msvc-base", "release-base"]
    }
  ],
  "buildPresets": [
    {
      "name": "msvc-debug",
      "configurePreset": "msvc-debug",
      "verbose": true
    },
    {
      "name": "msvc-release",
      "configurePreset": "msvc-release"
    }
  ],
  "testPresets": [
    {
      "name": "base",
      "hidden": true,
      "environment": {
        "MAYONES_TEST_CORE_DATA": "${sourceDir}/tests/core/data",
        "MAYONES_NESTEST_ROM": "$env{MAYONES_TEST_CORE_DATA}/nestest.nes",
        "MAYONES_NESTEST_TRACE": "$env{MAYONES_TEST_CORE_DATA}/nestest_official.txt"
      },
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "msvc-debug",
      "inherits": ["base"],
      "configurePreset": "msvc-debug"
    },
    {
      "name": "msvc-release",
      "inherits": ["base"],
      "configurePreset": "msvc-release"
    }
  ]
}
